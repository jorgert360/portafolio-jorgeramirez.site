# Variables de entorno — Portafolio-Ramtroz
# Copia este archivo como .env.local y completa los valores

# Google Analytics 4 (opcional — el sitio funciona sin esto)
# Ve a https://analytics.google.com → crea una propiedad → copia el ID "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=

# Google Search Console (opcional — para verificar la propiedad del sitio)
# Search Console → Añadir propiedad → Verificación por "Etiqueta HTML"
# → copia SOLO el valor del atributo content (sin la etiqueta <meta>)
GOOGLE_SITE_VERIFICATION=

# Resend — Para el envío de correos desde el formulario de contacto
# 1. Ve a https://resend.com → regístrate (gratis)
# 2. Ve a API Keys → crea una nueva key
# 3. Copia el valor "re_xxxxxxxxxx" aquí abajo
# 4. Reinicia el servidor de desarrollo
# NOTA: En producción, configura esta variable en Vercel (Settings → Environment Variables)
RESEND_API_KEY=

# Para pruebas locales sin Resend: los mensajes se registran en la consola del terminal
# y verás algo como: [contacto] Nuevo mensaje: {...}
